<Page x:Class="ChmlFrp_Professional_Launcher.Pages.ChmlFrpPages.Login.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ChmlFrp_Professional_Launcher"
      mc:Ignorable="d" 
      Height="225"
      Width="425"
      Title="LoginPage">

    <Grid>
        <StackPanel Orientation="Vertical" VerticalAlignment="Center" Margin="0,20,0,0">

            <local:CornerTextBox CornerRadius="5"
                                         x:Name="TextBox_Username"
                                         Height="35"
                                         Width="380"
                                         Margin="0,-25,0,0"
                                         TextTwo="用户名或邮箱"
                                         GotFocus="TextBox_Username_GotFocus"
                                         LostFocus="TextBox_Username_LostFocus"/>

            <local:CornerTextBox x:Name="TextBox_password"
                                         CornerRadius="5"
                                         Height="35"
                                         Width="380"
                                         Margin="0,5,0,0"
                                         TextTwo="密码" 
                                         GotFocus="TextBox_password_GotFocus"
                                         LostFocus="TextBox_password_LostFocus"/>
        </StackPanel>

        <StackPanel Orientation="Vertical">
            <TextBlock x:Name="SubjectTextBlock" 
                               FontSize="25" 
                               Text="登录CHMLFRP" 
                               Foreground="#0B5BCB" Margin="20,20,0,0" 
                               VerticalAlignment="Top" 
                               HorizontalAlignment="Left" />

            <Border CornerRadius="2,2,2,2" 
                            Background="#116fce" 
                            Width="400" 
                            Height="2" 
                            Margin="0,4,0,0" />

        </StackPanel>

        <!--<local:CornerButten Margin="25,0,0,25"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Bottom"
                            FontSize="14" 
                            CornerRadius="3" 
                            Content="注册" 
                            IsSelected="True"
                            Click="Registerpage_Navigate"
                            Height="35"
                            Width="60"/>-->
        
        <StackPanel Margin="0,0,25,25" 
                            VerticalAlignment="Bottom" 
                            HorizontalAlignment="Right"
                            Orientation="Horizontal">

            <local:CornerButten Margin="0,0,5,0"
                                        FontSize="14" 
                                        CornerRadius="3" 
                                        Content="退出" 
                                        IsSelected="True"
                                        Click="exit"
                                        Height="35"
                                        Width="60"/>

            <local:CornerButten FontSize="14" 
                                        CornerRadius="3" 
                                        Content="登录" 
                                        IsSelected="True"
                                        x:Name="logonButton"
                                        Click="logon"
                                        Height="35"
                                        Width="60"/>

        </StackPanel>
    </Grid>
</Page>
