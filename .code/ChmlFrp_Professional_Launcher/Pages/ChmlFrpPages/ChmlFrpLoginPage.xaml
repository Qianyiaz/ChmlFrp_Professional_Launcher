<Page x:Class="ChmlFrp_Professional_Launcher.Pages.ChmlFrpLoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="370"
      d:DesignWidth="770"
      Title="ChmFrp">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition Width="360"/>
        </Grid.ColumnDefinitions>

        <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="Sign In to"
                            Margin="0,-25,0,0"
                            FontSize="30"
                            FontFamily="Bold"/>
            <TextBlock Text="ChmlFrp Panel"
                            Margin="0,35,0,0"
                            FontSize="30"
                            FontFamily="Bold"/>
        </StackPanel>

        <Border Width="360"
                Grid.Column="1"
                Opacity="0.8"
                Background="#f9f9f9"
                HorizontalAlignment="Right"
                CornerRadius="0,0,6,0">
            <Grid>
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Orientation="Vertical">

                    <TextBox TextChanged="TextBox_Username_ini"
                             x:Name="TextBox_Username"
                             Height="35"
                             Width="320"
                             Margin="0,-25,0,0"
                             Foreground="Gray"
                             BorderBrush="{x:Null}"
                             FontSize="16"
                             FontFamily="Bold"
                             GotFocus="TextBox_GotFocus"
                             LostFocus="TextBox_LostFocus"
                             Text="用户名或邮箱"
                             TextAlignment="Left"
                             VerticalContentAlignment="Center">
                        <TextBox.Resources>
                            <Style TargetType="{x:Type TextBox}">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type TextBox}">
                                            <Border Background="Transparent"
                                                    CornerRadius="15"
                                                    BorderBrush="Black"
                                                    BorderThickness="1">
                                                <ScrollViewer x:Name="PART_ContentHost" Padding="10,0,0,0"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>

                    <PasswordBox x:Name="TextBox_password"
                             Height="35"
                             Width="320"
                             Margin="0,25,0,0"
                             Foreground="Black"
                             BorderBrush="{x:Null}"
                             FontSize="16"
                             FontFamily="Bold"
                             VerticalContentAlignment="Center">
                        <PasswordBox.Resources>
                            <Style TargetType="{x:Type PasswordBox}">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type PasswordBox}">
                                            <Border Background="Transparent"
                                                    CornerRadius="15"
                                                    BorderBrush="Black"
                                                    BorderThickness="1">
                                                <ScrollViewer x:Name="PART_ContentHost" Padding="10,0,0,0"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </PasswordBox.Resources>
                    </PasswordBox>

                    <Button Foreground="{DynamicResource TextPrimaryColor}"
                            FontWeight="ExtraLight"
                            Background="Transparent"
                            Content="登录"
                            FontSize="15"
                            Width="340"
                            Height="45"
                            Margin="0,55,0,0"
                            x:Name="logonButton"
                            Click="logon">
                        <Button.Resources>
                            <Style TargetType="{x:Type Border}">
                                <Setter Property="CornerRadius"
                                        Value="15"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>