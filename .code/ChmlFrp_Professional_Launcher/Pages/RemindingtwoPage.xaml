<Page x:Class="ChmlFrp_Professional_Launcher.Pages.RemindingtwoPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:ChmlFrp_Professional_Launcher"
      mc:Ignorable="d"
      d:DesignHeight="430" d:DesignWidth="780"
      Title="RemindingtwoPage">

    <Grid>
        <Border CornerRadius="6,6,6,6"
                Background="Black"
                Opacity="0.4">
            <!--移动窗口的Border-->
            <Border  CornerRadius="6,6,0,0"
                     VerticalAlignment="Top"
                     HorizontalAlignment="Center"
                     MouseLeftButtonDown="Border_MouseLeftButtonDown"
                     Width="780"
                     Height="50"
                     Background="Transparent">
            </Border>
        </Border>
        <Border CornerRadius="6,6,6,6"
                Height="225"
                Width="425"
                Background="#f9f9f9"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">
            <Grid>
                <StackPanel Orientation="Vertical">
                    <TextBlock x:Name="SubjectTextBlock" FontSize="25" Text="我是擎天柱" Foreground="#0B5BCB" Margin="20,20,0,0" VerticalAlignment="Top" HorizontalAlignment="Left" />
                    <Border CornerRadius="2,2,2,2" Background="#116fce" Width="400" Height="2" Margin="0,4,0,0" />
                    <TextBlock x:Name="TextTextBlock" FontSize="16" Margin="25,10,0,0" Text="我是擎天柱" Foreground="#5C5C5C" />
                </StackPanel>
                <local:ReallyCornerButten FontSize="14" CornerRadius="3" Content="确定" Click="Yes_Button_Click" BorderThickness="1" BorderBrush="Black" Background="Transparent" Width="55" Height="35" Margin="0,0,25,25" VerticalAlignment="Bottom" HorizontalAlignment="Right" />
            </Grid>
        </Border>
    </Grid>
</Page>