<Window x:Class="ChmlFrp_Professional_Launcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ChmlFrp_Professional_Launcher"
        xmlns:wi="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Height="450"
        Width="800"
        MinWidth="800"
        MinHeight="450"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResize"
        Background="Transparent"
        WindowState="Normal"
        Title="ChmlFrp_Professional_Launcher">

    <Border Background="Transparent">
        <Grid>
            <Grid Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="50" />
                    <RowDefinition />
                </Grid.RowDefinitions>

                <Border  CornerRadius="6,6,0,0"
                     MouseLeftButtonDown="Border_MouseLeftButtonDown"
                     Grid.Row="0"
                     Height="50"
                     Background="#1276DB">
                    <Grid>
                        <Grid Margin="0,0,520,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60" />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>

                            <Path Data="{DynamicResource logo}"
                              Stretch="Fill"
                              Fill="#CFE2F7"
                              Width="25"
                              Height="25"
                              RenderTransformOrigin="0.5,0.5">
                                <Path.RenderTransform>
                                    <TransformGroup>
                                        <ScaleTransform ScaleX="-1" />
                                        <SkewTransform />
                                        <RotateTransform Angle="-180" />
                                        <TranslateTransform />
                                    </TransformGroup>
                                </Path.RenderTransform>
                            </Path>
                        </Grid>

                        <Grid>
                            <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal">

                                <local:CornerButten
                                    IsChecked="True"
                                    Content="启动"
                                    Width="75"
                                    Height="30"
                                    BorderBrush="{x:Null}"
                                    x:Name="LaunchPageButton"
                                    CornerRadius="20"
                                    Click="rdLaunchPage_Click" />

                                <local:CornerButten
                                    Content="登录"
                                    Width="75"
                                    Height="30"
                                    BorderBrush="{x:Null}"
                                    x:Name="ChmlfrpPageButton"
                                    CornerRadius="20"
                                    Click="rdChmlfrpPage_Click" />

                                <local:CornerButten
                                    Content="设置"
                                    Width="75"
                                    Height="30"
                                    BorderBrush="{x:Null}"
                                    x:Name="SettingsPageButton"
                                    CornerRadius="20"
                                    Click="rdSettingsPage_Click" />
                            </StackPanel>
                        </Grid>

                        <StackPanel HorizontalAlignment="Right"
                                Orientation="Horizontal"
                                FlowDirection="RightToLeft"
                                Height="50"
                                Width="100">
                            <Grid Width="15" />
                            <Button x:Name="btnClose"
                                Margin="5"
                                Height="25"
                                Width="25"
                                Style="{StaticResource IconButtonsStyle}"
                                Content="{DynamicResource close}"
                                Click="btnClose_Click"
                                Tag="IsCloseButton" />
                            <Button x:Name="btnMinimize"
                                Height="25"
                                Width="25"
                                Style="{StaticResource IconButtonsStyle}"
                                Content="{DynamicResource minimize}"
                                Click="btnMinimize_Click" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Row="1">
                    <Border Background="#C7D7EE"
                        CornerRadius="0,0,6,6" />
                    <Border CornerRadius="0,0,5,5">
                        <Border.Background>
                            <ImageBrush Opacity="0.8"
                                    x:Name="Imagewallpaper" />
                        </Border.Background>
                    </Border>
                    <Border CornerRadius="0,0,6,6">
                        <Frame x:Name="PagesNavigation"
                           NavigationUIVisibility="Hidden">
                        </Frame>
                    </Border>
                    <ResizeGrip HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            Margin="0,0,10,10" />
                </Grid>
            </Grid>

            <Grid Margin="15">
                <Border CornerRadius="5">
                    <Frame x:Name="PagesNavigationtwo"
                           NavigationUIVisibility="Hidden">
                    </Frame>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>